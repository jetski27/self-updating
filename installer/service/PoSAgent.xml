<!--
  WinSW (Windows Service Wrapper) descriptor for PoS Agent.

  Distribution model: a plain zip the user extracts somewhere (e.g.
  C:\posagent\) and registers as a service via install-service.bat. No
  jpackage / MSI / bundled JRE — the client is expected to have Java 21+
  installed and JAVA_HOME set system-wide.

  Lifecycle:
    1. SCM starts the service. WinSW invokes %JAVA_HOME%\bin\java.exe
       against launcher.jar (which sits next to PoSAgent.exe). The
       launcher's --service flag picks %ProgramData%\PoS Agent\ for
       state and skips the splash + browser-open.
    2. The launcher's supervisor loop owns Quarkus restarts: update4j
       checks GitHub Releases, downloads only changed files, then boots
       the Quarkus child JVM. .restart-pending marker drives
       in-process restarts; SCM only sees one long-running process.
    3. SCM stop -> service-mode shutdown hook drains the Quarkus child
       and exits the supervisor cleanly. Exit code 0 = service stopped,
       no automatic restart.

  Path placeholders WinSW substitutes at runtime:
    %BASE%        directory containing this XML and PoSAgent.exe
    %JAVA_HOME%   from the system environment (must be set machine-wide
                  so LocalSystem inherits it; user-only JAVA_HOME won't
                  reach the service)
-->
<service>
    <id>PoSAgent</id>
    <name>PoS Agent</name>
    <description>PoS Agent — self-updating desktop application by Azry. Polls GitHub Releases hourly and applies updates on restart.</description>

    <executable>%JAVA_HOME%\bin\java.exe</executable>
    <arguments>-jar "%BASE%\launcher.jar" --service</arguments>
    <workingdirectory>%BASE%</workingdirectory>

    <!-- Service starts at boot but after the network stack is up. The
         launcher's first action is a GitHub API call. -->
    <startmode>Automatic</startmode>
    <delayedAutoStart>true</delayedAutoStart>
    <depend>Tcpip</depend>

    <!-- LocalSystem because it inherits machine-wide JAVA_HOME and has
         the privilege to read/write %ProgramData%. Switch to a
         dedicated service account if you need defense-in-depth. -->
    <serviceaccount>
        <username>LocalSystem</username>
        <allowservicelogon>true</allowservicelogon>
    </serviceaccount>

    <!-- WinSW captures launcher stdout/stderr here. The launcher itself
         additionally rolls its own log into %ProgramData%\PoS Agent\logs\
         via java.util.logging, and Quarkus rolls posagent.log there too. -->
    <logpath>%ProgramData%\PoS Agent\logs</logpath>
    <log mode="roll-by-size">
        <sizeThreshold>5120</sizeThreshold>
        <keepFiles>3</keepFiles>
    </log>

    <!-- If the launcher process itself dies (its in-process supervisor
         loop died too), back off and let SCM restart it. Reset failure
         count after an hour of stable uptime. -->
    <onfailure action="restart" delay="5 sec"/>
    <onfailure action="restart" delay="30 sec"/>
    <onfailure action="restart" delay="60 sec"/>
    <resetfailure>1 hour</resetfailure>

    <!-- 30 s for the launcher to drain — destroying the Quarkus child
         and joining waitFor() should take well under that. -->
    <stoptimeout>30 sec</stoptimeout>

    <stopparentprocessfirst>true</stopparentprocessfirst>
</service>
