<?xml version="1.0" encoding="UTF-8"?>
<!--
  Launch4j wraps launcher.jar into MyApp.exe.
  Bundled-first JRE search order so the JRE shipped by jpackage is used.
  stayAlive = true so the EXE stays attached to the Java process (clean Ctrl+C / exit codes).
-->
<launch4jConfig>
    <dontWrapJar>false</dontWrapJar>
    <headerType>gui</headerType>
    <jar>../launcher/target/launcher.jar</jar>
    <outfile>../installer/MyApp.exe</outfile>
    <errTitle>MyApp</errTitle>
    <cmdLine></cmdLine>
    <chdir>.</chdir>
    <priority>normal</priority>
    <downloadUrl>https://adoptium.net/</downloadUrl>
    <supportUrl></supportUrl>
    <stayAlive>true</stayAlive>
    <restartOnCrash>false</restartOnCrash>
    <manifest></manifest>
    <icon>../installer/app.ico</icon>
    <classPath>
        <mainClass>com.example.myapp.launcher.Launcher</mainClass>
    </classPath>
    <jre>
        <path>runtime</path>
        <bundledJre64Bit>true</bundledJre64Bit>
        <bundledJreAsFallback>false</bundledJreAsFallback>
        <minVersion>21</minVersion>
        <jdkPreference>preferJre</jdkPreference>
        <runtimeBits>64</runtimeBits>
        <opt>-Dapp.home=%APPDATA%\MyApp</opt>
        <opt>-Dgithub.owner=jetski27</opt>
        <opt>-Dgithub.repo=self-updating</opt>
    </jre>
    <versionInfo>
        <fileVersion>1.0.0.0</fileVersion>
        <txtFileVersion>1.0.0</txtFileVersion>
        <fileDescription>MyApp self-updating launcher</fileDescription>
        <copyright>Copyright (c) MyApp contributors</copyright>
        <productVersion>1.0.0.0</productVersion>
        <txtProductVersion>1.0.0</txtProductVersion>
        <productName>MyApp</productName>
        <companyName>MyApp</companyName>
        <internalName>myapp</internalName>
        <originalFilename>MyApp.exe</originalFilename>
    </versionInfo>
</launch4jConfig>
